rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Members collection
    match /members/{memberId} {
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.paymentStatus == 'unpaid'
        && request.resource.data.keys().hasAll([
          'firstName', 'lastName', 'businessName', 'email', 'phone',
          'businessCategory', 'membershipTier', 'businessDescription',
          'socialMedia', 'agreedToTerms', 'status', 'paymentStatus',
          'createdAt', 'updatedAt'
        ]);

      allow read: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /registrations/{registrationId} {
        allow create: if request.resource.data.keys().hasAll([
          'name', 'email', 'status', 'registeredAt'
        ]) && request.resource.data.status == 'registered';

        allow read, update, delete: if isAdmin();
      }
    }

    match /feedback/{feedbackId} {
      allow create: if request.resource.data.keys().hasAll([
        'eventId', 'rating', 'liked', 'improvements',
        'topicSuggestions', 'wouldAttendAgain', 'createdAt'
      ]) && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
